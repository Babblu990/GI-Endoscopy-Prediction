
{
  "entities": {
    "Prediction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Prediction",
      "type": "object",
      "description": "Represents a combined endoscopic image and its AI diagnostic results.",
      "properties": {
        "id": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string", "format": "uri" },
        "originalFileName": { "type": "string" },
        "overallPrediction": { "type": "string" },
        "overallConfidence": { "type": "number" },
        "status": { "type": "string" },
        "vgg16": {
          "type": "object",
          "properties": {
            "prediction": { "type": "string" },
            "confidence": { "type": "number" }
          }
        },
        "resnet50": {
          "type": "object",
          "properties": {
            "prediction": { "type": "string" },
            "confidence": { "type": "number" }
          }
        },
        "inceptionV3": {
          "type": "object",
          "properties": {
            "prediction": { "type": "string" },
            "confidence": { "type": "number" }
          }
        }
      },
      "required": ["id", "uploadedAt", "imageUrl", "overallPrediction", "overallConfidence"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/predictions/{predictionId}": {
      "schema": { "$ref": "#/backend/entities/Prediction" },
      "description": "Stores diagnostic predictions globally for the clinical portal."
    }
  }
}
