/**
 * GI Endoscopic Disease Detection System - Security Rules
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model where all data is private by default. 
 * Authorization is primarily path-based, leveraging the hierarchical structure of Firestore 
 * to ensure that users can only access their own profiles and prediction history.
 *
 * Data Structure:
 * All application data is organized under the top-level `/users/{userId}` path. 
 * - `/users/{userId}`: Contains the user's profile information.
 * - `/users/{userId}/predictions/{predictionId}`: Contains AI diagnostic results for images uploaded by the user.
 *
 * Key Security Decisions:
 * 1. Strict Ownership: Access to any document requires the authenticated user's UID to match 
 *    the `{userId}` wildcard in the document path.
 * 2. No Public Access: There are no public read or write permissions; all operations 
 *    require a valid Firebase Authentication session.
 * 3. Prototyping Flexibility: While authorization is strictly enforced (who can access what), 
 *    the specific fields within the data (except for relational IDs) are not validated 
 *    to allow for rapid iteration on the AI model outputs.
 *
 * Denormalization for Authorization:
 * Each `Prediction` document includes a denormalized `userId` field. This ensures that 
 * authorization logic can be validated against both the path and the document content 
 * without requiring cross-collection lookups, maximizing performance and security integrity.
 *
 * Structural Segregation:
 * User profiles and their diagnostic history are segregated into distinct subcollections. 
 * This prevents accidental data exposure and simplifies query-based authorization for 
 * historical report listing.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner and the document exists (for update/delete).
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the user profile document.
     * @path /users/{userId}
     * @allow (create) User 'abc' creates document /users/abc.
     * @deny (create) User 'abc' attempts to create /users/xyz.
     * @principle Pattern 4: Self-Creation. Enforces that users can only manage their own root profile.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      /**
       * @description Rules for individual AI prediction records.
       * @path /users/{userId}/predictions/{predictionId}
       * @allow (create) User 'abc' uploads a prediction to their own subcollection with userId 'abc' in data.
       * @deny (list) User 'abc' attempts to list predictions under /users/xyz/predictions.
       * @principle Pattern 1: Ownership. Validates relational integrity by ensuring the userId in the document matches the path.
       */
      match /predictions/{predictionId} {
        allow get, list: if isOwner(userId);
        
        // On create: Ensure the user owns the path AND the data matches the owner
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        
        // On update: Ensure the user owns the document and the userId field remains immutable
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        
        // On delete: Ensure the user owns the document and it actually exists
        allow delete: if isExistingOwner(userId);
      }
    }

    // Default deny for any unmatched paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}